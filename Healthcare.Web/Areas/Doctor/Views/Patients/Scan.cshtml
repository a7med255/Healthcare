@model Healthcare.Web.ViewModels.Doctor.ScanPatientViewModel
@{
    ViewData["Title"] = "Scan Patient";
}
<div class="row justify-content-center"><div class="col-md-6"><div class="card border-0 shadow-sm"><div class="card-body p-4">
    <h1 class="h3">Scan patient QR</h1>
    <p class="text-secondary">Enter the scanned QR token and patient PIN to view history.</p>
    <form asp-action="Scan" method="post" novalidate>
        <div class="mb-3"><label asp-for="QrCodeToken" class="form-label"></label><input asp-for="QrCodeToken" class="form-control" /><span asp-validation-for="QrCodeToken" class="text-danger"></span></div>
        <div class="mb-3"><label asp-for="PatientPin" class="form-label"></label><input asp-for="PatientPin" class="form-control" maxlength="4" inputmode="numeric" /><span asp-validation-for="PatientPin" class="text-danger"></span></div>
        <button class="btn btn-primary" type="submit">View patient history</button>
    </form>
</div></div></div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
