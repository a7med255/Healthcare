@model Healthcare.Web.ViewModels.Doctor.DoctorDashboardViewModel
@{
    ViewData["Title"] = "Doctor Dashboard";
}
<div class="d-flex justify-content-between align-items-center mb-4">
    <div><h1 class="h3">Doctor dashboard</h1><p class="text-secondary mb-0">@Model.FullName · Syndicate: @Model.MedicalSyndicateNumber</p></div>
    <a class="btn btn-primary" asp-area="Doctor" asp-controller="Patients" asp-action="Scan">Scan patient QR</a>
</div>
@if (!Model.IsApproved)
{
    <div class="alert alert-warning">Your doctor permissions are pending admin approval. Until approval, you can continue using patient features.</div>
}
<div class="row g-4"><div class="col-md-4"><div class="card border-0 shadow-sm"><div class="card-body"><span class="text-secondary">Records this month</span><div class="display-6 fw-bold">@Model.RecordsCreatedThisMonth</div></div></div></div></div>
