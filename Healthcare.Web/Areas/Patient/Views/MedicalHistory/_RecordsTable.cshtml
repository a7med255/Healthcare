@model IReadOnlyList<Healthcare.Web.ViewModels.Patient.MedicalRecordSummaryViewModel>
@if (Model.Count == 0)
{
    <div class="text-center text-secondary py-4">No medical records available yet.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead><tr><th>Visit Date</th><th>Doctor</th><th>Diagnosis</th><th>Syndicate #</th><th>Images</th></tr></thead>
            <tbody>
            @foreach (var record in Model)
            {
                <tr><td>@record.VisitDateUtc.ToLocalTime().ToString("yyyy-MM-dd")</td><td>@record.DoctorName</td><td>@record.Diagnosis</td><td>@record.MedicalSyndicateNumber</td><td>@record.PrescriptionImageCount</td></tr>
            }
            </tbody>
        </table>
    </div>
}
